rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }

    // Validation Blueprint for Digest
    function isValidDigest(data) {
      return data.userId == request.auth.uid 
        && data.summary is string && data.summary.size() <= 50000
        && data.newProducts is list
        && data.existingProducts is list
        && data.createdAt == request.time
        && data.status in ['sent', 'pending', 'failed'];
    }

    function isValidSettings(data) {
      return data.userId == request.auth.uid
        && (data.email == null || (data.email is string && data.email.size() <= 200))
        && (data.searchQuery == null || (data.searchQuery is string && data.searchQuery.size() <= 2000))
        && data.updatedAt == request.time;
    }

    // Digests collection
    match /digests/{digestId} {
      // Secure list and individual reads
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Secure creation with schema validation
      allow create: if isSignedIn() && isValidDigest(incoming());
      
      // Allow atomic status updates (sent/failed)
      allow update: if isSignedIn() 
        && isOwner(resource.data.userId)
        && incoming().diff(resource.data).affectedKeys().hasOnly(['status']);
        
      allow delete: if false;
    }

    // Settings collection
    match /settings/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidSettings(incoming());
    }
  }
}
